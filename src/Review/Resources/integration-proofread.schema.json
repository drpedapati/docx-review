{
  "type": "object",
  "additionalProperties": false,
  "required": [
    "patterns",
    "review_letter"
  ],
  "properties": {
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "pattern",
          "category",
          "examples"
        ],
        "properties": {
          "pattern": {
            "type": "string"
          },
          "examples": {
            "type": ["array", "null"],
            "items": {
              "type": "string"
            }
          },
          "category": {
            "type": "string",
            "enum": [
              "grammar",
              "punctuation",
              "style",
              "formatting",
              "consistency",
              "readability"
            ]
          }
        }
      }
    },
    "review_letter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "overall_assessment",
        "key_findings",
        "recommendations",
        "highlights",
        "concerns"
      ],
      "properties": {
        "overall_assessment": {
          "type": "string"
        },
        "key_findings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "category",
              "description",
              "severity"
            ],
            "properties": {
              "category": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "severity": {
                "type": ["string", "null"],
                "enum": [
                  "high",
                  "medium",
                  "low",
                  null
                ]
              }
            }
          }
        },
        "highlights": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "concerns": {
          "type": ["array", "null"],
          "items": {
            "type": "string"
          }
        },
        "recommendations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
